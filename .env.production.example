# Buca Yıldız — ÜRETİM ortam değişkenleri ŞABLONU
# Sunucuda bu dosyayı `.env` (veya hosting panelinin "Environment Variables"
# bölümüne) doldurarak kullanın. Gerçek değerleri ASLA git'e koymayın.
#
# KVKK: Veritabanı ve yedekler Türkiye'de barındırılmalıdır.

# --- Veritabanı (Türkiye'deki PostgreSQL) ---
# sslmode=require: bağlantı şifreli olsun (uzak DB'lerde zorunlu sayın).
# Örnek: postgresql://KULLANICI:PAROLA@db-sunucu.example.tr:5432/bucayildiz?schema=public&sslmode=require
DATABASE_URL="postgresql://KULLANICI:PAROLA@DB_SUNUCU:5432/bucayildiz?schema=public&sslmode=require"

# --- KVKK onay metni sürümü ---
NEXT_PUBLIC_CONSENT_VERSION="2026-06-14"

# --- Auth: oturum JWT imzalama anahtarı (ZORUNLU: güçlü rastgele) ---
# Üret: openssl rand -hex 32
AUTH_SECRET="BURAYA_OPENSSL_RAND_HEX_32_DEGERI"

# --- İlk admin (yalnızca ilk seed için; sonra kaldırılabilir) ---
SEED_ADMIN_EMAIL="admin@bucayildiz.com"
SEED_ADMIN_PASSWORD="DEGISTIR_guclu_bir_parola"
SEED_ADMIN_NAME="Yönetici Ad Soyad"

# --- Node ortamı ---
NODE_ENV="production"

# --- Web Push (VAPID) — PROD için KENDİ anahtarlarını üret ---
# node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:bilgi@bucayildiz.com"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""   # VAPID_PUBLIC_KEY ile AYNI değer (istemciye açılır)

# --- E-posta/SMTP — başvuru bildirimleri (boşsa atlanır) ---
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="Buca Yıldız <bilgi@bucayildiz.com>"
MAIL_TO_ADMIN="admin@bucayildiz.com"

# --- Dosya depolama (S3-uyumlu, Türkiye) — boşsa yerel disk ---
# Turkcell Object Storage, MinIO veya benzeri S3-uyumlu servis.
S3_ENDPOINT=""           # örn. https://objects.example.tr  (AWS S3 için boş bırak)
S3_REGION="auto"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_BASE_URL=""    # CDN/genel erişim kökü (opsiyonel)

# --- SMS (veli OTP + bildirim) — Türkiye sağlayıcısı (Netgsm vb.), boşsa atlanır ---
SMS_API_URL=""
SMS_API_USER=""
SMS_API_KEY=""
SMS_SENDER=""            # onaylı başlık (mesaj başlığı)
