// Buca Yıldız — Prisma schema
//
// PostgreSQL (dev: bu makinede native PG18 :5432, prod: Türkiye'de barındırılacak).
// Şema sade tutuldu (enum yok, status String) — taşıma ve bakım kolaylığı için.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Ücretsiz deneme / akademi başvurusu (KVKK açık rıza + audit log ile).
model Application {
  id               String   @id @default(cuid())
  athleteName      String
  birthDate        String // "YYYY-MM-DD" — TZ sorunlarını önlemek için String
  ageGroup         String // doğum tarihinden türetilir (form'da seçilmez)
  position         String?
  currentClub      String? // mevcut kulüp (var ise) — opsiyonel
  parentName       String // sorumlu kişi: minörde veli, yetişkinde sporcunun kendisi
  phone            String
  email            String?
  kvkkConsent      Boolean  @default(false) // aydınlatma + açık rıza (zorunlu)
  marketingConsent Boolean  @default(false) // bülten/kampanya (opsiyonel)
  consentVersion   String // onaylanan metnin sürümü (ispat için)
  ipAddress        String? // audit: ispat yükü veri sorumlusunda
  userAgent        String?
  status           String   @default("new") // new | contacted | scheduled | closed
  createdAt        DateTime @default(now())

  consents ConsentRecord[]

  @@index([status])
  @@index([createdAt])
}

/// KVKK onay metinleri — sürümlü, avukat tarafından yazılır/onaylanır.
/// Her metin ayrı bir belge (battaniye "hepsini kabul" rızası KVKK'da geçersiz).
model ConsentDocument {
  id        String   @id @default(cuid())
  key       String // aydinlatma | acik-riza | saglik-verisi | foto-video | uyelik
  version   String // "2026-06-15" — ispat için sürüm
  title     String
  summary   String // formdaki kısa onay cümlesi
  body      String // tam metin (placeholder; avukat onayı bekleniyor)
  isConsent Boolean  @default(true) // false = sadece aydınlatma/bilgilendirme (rıza değil)
  required  Boolean  @default(true) // false = opsiyonel (foto-video, pazarlama) — kayda bağlanamaz
  ordering  Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([key, version])
  @@index([active])
}

/// Bir onayın verildiği/geri alındığı an — KVKK ispat/denetim kaydı.
/// Hangi metin (key+sürüm+hash), kim (veli), nasıl (IP/UA/OTP), ne zaman.
model ConsentRecord {
  id              String   @id @default(cuid())
  documentKey     String
  documentVersion String
  documentTitle   String // o anki başlık (anlık görüntü — ispat)
  textHash        String // metnin SHA-256'sı (sonradan değişmediğinin ispatı)
  granted         Boolean // true = verildi, false = reddedildi/geri alındı
  granterName     String // rızayı veren (reşit değilse veli)
  granterRelation String? // veli | anne | baba | vasi | kendisi
  channel         String   @default("basvuru") // basvuru | veli-panel | admin
  ipAddress       String?
  userAgent       String?
  otpVerified     Boolean  @default(false) // SMS OTP doğrulandı mı (sağlayıcı bağlanınca)
  createdAt       DateTime @default(now())
  withdrawnAt     DateTime? // geri alındıysa

  applicationId String?
  application   Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  athleteId     String?
  athlete       Athlete?     @relation(fields: [athleteId], references: [id], onDelete: SetNull)

  @@index([applicationId])
  @@index([athleteId])
  @@index([documentKey])
}

/// Takım (A Takım, U-18…U-15).
model Team {
  id         String     @id @default(cuid())
  slug       String     @unique
  name       String
  short      String
  coach      String     @default("")
  born       String     @default("")
  coverImage String?
  sort       Int        @default(0)
  /// Ana takım (A Takım) — anasayfa kartında geniş gösterilir; tek takımda true olur.
  isMain     Boolean    @default(false)
  athletes   Athlete[]
  trainings  Training[]
  fixtures   Fixture[]
  createdAt  DateTime   @default(now())
}

/// Sporcu.
model Athlete {
  id        String   @id @default(cuid())
  name      String
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id])
  position  String   @default("")
  number    Int?
  height    Int? // cm
  weight    Int? // kg
  foot        String? // Sağ | Sol | Çift
  status      String   @default("active") // active | injured | rest
  licenseNo   String?
  photoUrl    String?
  birthYear   Int? // (kullanımdan kalktı — birthDate'e taşındı)
  birthDate   String? // "YYYY-MM-DD"
  parentPhone String?
  user         User?
  measurements PerformanceMeasurement[]
  consents     ConsentRecord[]
  pushSubs     PushSubscription[]
  payments     Payment[]
  trainingAttendance TrainingAttendance[]
  assignments        AthleteAssignment[]
  nutritionPlans     NutritionPlan[]
  mealLogs           MealLog[]
  notifications      Notification[]
  createdAt    DateTime @default(now())

  @@index([teamId])
  @@index([status])
}

/// Sporcu performans ölçümü (panel matrisi + admin girişi).
/// Periyodik performans ölçümü. Sporcu başına ÇOK kayıt — her ölçüm tarihlidir.
/// En güncel ölçüm = sporcunun mevcut durumu; geçmiş kayıtlar raporlama/trend
/// için korunur. (Eski 1:1 Performance + vo2History JSON yapısının yerini aldı.)
model PerformanceMeasurement {
  id               String   @id @default(cuid())
  athleteId        String
  athlete          Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  measuredAt       String // "YYYY-MM-DD" — ölçüm tarihi (zorunlu)
  // Dayanıklılık — VO2max yoyoLevel + yoyoDistance'tan otomatik hesaplanır (saklanmaz).
  yoyoLevel        String? // "IR1" | "IR2"
  yoyoDistance     Float? // m
  repeatedSprint   Float? // sn (tekrarlı sprint testi)
  // Vücut kompozisyonu
  bodyFat          Float? // %
  muscle           Float? // %
  // Sürat
  sprint10         Float? // sn
  sprint20         Float? // sn
  sprint30         Float? // sn (max sürat 30m)
  // Kuvvet
  verticalJump     Float? // cm (dikey sıçrama)
  standingLongJump Float? // cm (durarak uzun atlama)
  // Çeviklik
  tTest            Float? // sn
  agility505       Float? // sn
  note             String?
  createdAt        DateTime @default(now())

  @@index([athleteId, measuredAt])
}

/// Forma (İç Saha, Deplasman, Üçüncü, Kaleci…).
model Jersey {
  id          String   @id @default(cuid())
  name        String
  kind        String   @default("home") // home | away | third | gk | other
  primary     String   @default("#15295A")
  accent      String   @default("#C9A227")
  description String   @default("")
  imageUrl    String?
  active      Boolean  @default(true)
  sort        Int      @default(0)
  createdAt   DateTime @default(now())
}

/// Medya kategorisi (ana sayfadaki "Görseller & Videolar" kartlarını besler).
model MediaCategory {
  id        String          @id @default(cuid())
  name      String
  color     String          @default("#15295A")
  sort      Int             @default(0)
  assets    MediaAsset[]
  homeCards HomeMediaCard[]
  folders   Folder[]
  createdAt DateTime        @default(now())
}

/// Medya klasörü (iç içe ağaç).
model Folder {
  id         String         @id @default(cuid())
  name       String
  parentId   String?
  parent     Folder?        @relation("FolderTree", fields: [parentId], references: [id])
  children   Folder[]       @relation("FolderTree")
  assets     MediaAsset[]
  // Klasör bir kategoriye bağlanabilir; bağlıysa içine eklenen medya o kategoriyi
  // otomatik devralır (değiştirilemez). Bağlı değilse medya için kategori zorunlu.
  categoryId String?
  category   MediaCategory? @relation(fields: [categoryId], references: [id])
  createdAt  DateTime       @default(now())

  @@index([parentId])
  @@index([categoryId])
}

/// Medya varlığı (foto/video).
model MediaAsset {
  id         String         @id @default(cuid())
  url        String
  title      String         @default("")
  kind       String         @default("photo") // photo | video
  categoryId String?
  category   MediaCategory? @relation(fields: [categoryId], references: [id])
  folderId   String?
  folder     Folder?        @relation(fields: [folderId], references: [id])
  createdAt  DateTime       @default(now())

  @@index([categoryId])
  @@index([folderId])
}

/// Ana sayfa "Görseller & Videolar" kartı (bir kategoriyi besler).
model HomeMediaCard {
  id            String         @id @default(cuid())
  title         String
  categoryId    String?
  category      MediaCategory? @relation(fields: [categoryId], references: [id])
  kind          String         @default("photo") // photo | video
  featured      Boolean        @default(false)
  coverUrl      String? // kapak görseli — video kartta POSTER olarak da kullanılır
  coverVideoUrl String? // kapak videosu (yalnız kind=video; varsa autoplay-muted-loop oynar)
  sort          Int            @default(0)
  createdAt     DateTime       @default(now())
}

/// Haber / blog yazısı.
model Post {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  category    String   @default("")
  template    String   @default("standart")
  status      String   @default("draft") // draft | published | scheduled
  coverUrl    String?
  excerpt     String   @default("")
  body        String   @default("") // paragraflar çift satır ile ayrılır
  // Şablona özgü yapılandırılmış veri (JSON) — ör. macraporu: skor, goller,
  // maç kareleri; roportaj: soru-cevap blokları. Şablon editörleri doldurur.
  templateData String  @default("{}")
  author      String   @default("")
  featured    Boolean  @default(false)
  publishedAt String? // "YYYY-MM-DD"
  createdAt   DateTime @default(now())

  @@index([status])
  @@index([createdAt])
}

/// Antrenman programı kaydı (Takvim Programı). Maçlar burada TUTULMAZ —
/// takvim, yaklaşan maçları Fixture tablosundan otomatik gösterir.
model Training {
  id        String   @id @default(cuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id])
  scope     String   @default("team") // team | individual
  status    String   @default("planned") // planned | completed | cancelled | partial
  date      String // "YYYY-MM-DD"
  time      String   @default("") // "HH:MM"
  duration  Int? // dakika
  pitch     String   @default("")
  notes     String   @default("")
  createdAt DateTime @default(now())

  drills     TrainingDrill[]
  attendance TrainingAttendance[]

  @@index([teamId])
  @@index([date])
  @@index([status])
}

/// Antrenman içeriği maddesi (yapılacak çalışma). done = tamamlandı tiki.
model TrainingDrill {
  id         String   @id @default(cuid())
  trainingId String
  training   Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  text       String
  done       Boolean  @default(false)
  sort       Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([trainingId])
}

/// Yoklama + sporcuya özel not. Takım antrenmanında kadrodan türetilir
/// (kaydedildikçe upsert); bireyselde oluşturmada katılımcı olarak açılır.
model TrainingAttendance {
  id         String   @id @default(cuid())
  trainingId String
  training   Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  athleteId  String
  athlete    Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  status     String   @default("unknown") // present | absent | excused | unknown
  note       String   @default("") // sporcuya özel direktif/not
  createdAt  DateTime @default(now())

  @@unique([trainingId, athleteId])
  @@index([athleteId])
}

/// Maç / fikstür. Kulüp (Buca Yıldız) sabit; rakip manuel girilir.
model Fixture {
  id           String   @id @default(cuid())
  competition  String
  opponent     String
  opponentLogo String?
  isHome       Boolean  @default(true) // ev sahibi biz miyiz
  date         String // "YYYY-MM-DD"
  time         String   @default("") // "HH:MM"
  venue        String   @default("")
  status       String   @default("upcoming") // upcoming | finished
  ourScore     Int?
  oppScore     Int?
  teamId       String? // hangi takımın maçı (A Takım, U-18…)
  team         Team?    @relation(fields: [teamId], references: [id])
  createdAt    DateTime @default(now())

  @@index([date])
  @@index([status])
  @@index([teamId])
}

/// Panel kullanıcısı (admin veya sporcu). Sporcu, bir Athlete'e bağlıdır.
model User {
  id           String   @id @default(cuid())
  email        String?  @unique
  username     String?  @unique
  passwordHash String
  name         String
  role         String   @default("admin") // admin | athlete
  athleteId    String?  @unique
  athlete      Athlete? @relation(fields: [athleteId], references: [id])
  // Oturum sürümü: artırılınca bu kullanıcının eski JWT'leri geçersizleşir
  // (şifre değişimi / "her yerden çıkış"). Yetki kapısı DB'deki değerle karşılaştırır.
  tokenVersion Int      @default(0)
  pushSubs     PushSubscription[]
  createdAt    DateTime @default(now())
}

/// Web Push aboneliği (cihaz bazlı). KVKK: abonelik = opt-in; tek tıkla silinir.
/// Bildirim gövdesine sağlık/performans verisi YAZILMAZ (özel nitelikli veri).
model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  athleteId String?
  athlete   Athlete? @relation(fields: [athleteId], references: [id], onDelete: SetNull)
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([athleteId])
}

/// Site geneli ayarlar — TEK satır (id="site"). Kulüp, SEO, SMTP, görünüm.
model SiteSetting {
  id String @id @default("site")

  // Kulüp
  clubName      String  @default("Buca Yıldız Futbol Akademisi")
  clubShortName String  @default("Buca Yıldız")
  logoUrl       String?
  foundedYear   Int?
  phone         String?
  email         String?
  address       String?
  // Dinamik sosyal medya listesi — JSON: [{ platform, url }]. Aşağıdaki dört
  // eski alan geriye dönük okuma içindir; UI artık yalnız socialLinks yazar.
  socialLinks   String  @default("[]")
  instagramUrl  String?
  facebookUrl   String?
  youtubeUrl    String?
  xUrl          String?

  // SEO
  metaTitle       String?
  metaDescription String?
  ogImageUrl      String?
  keywords        String?

  // E-posta (SMTP) — DB'de tutulur; mail.ts önce buna, sonra env'e bakar.
  smtpHost    String?
  smtpPort    Int?    @default(587)
  smtpUser    String?
  smtpPass    String?
  mailFrom    String?
  mailToAdmin String?

  // Görünüm
  heroImageUrl          String? // ana sayfa hero arka plan görseli (boş = varsayılan)
  heroMobileImageUrl    String? // mobil (1:1) hero görseli (boş = heroImageUrl'e düşer)
  homeGalleryCategoryId String? // "Akademiden Kareler" kategori filtresi (boş = tümü)
  homeGalleryFeaturedUrl String? // "Akademiden Kareler" öne-çıkan görsel (medya kütüphanesinden)
  customCursor Boolean @default(false)
  cursorStyle  String  @default("star") // star | ball | whistle | default
  mobileNavAdmin Boolean @default(true) // yönetim panelinde mobil alt gezinme çubuğu
  mobileNavPanel Boolean @default(true) // sporcu panelinde mobil alt gezinme çubuğu

  updatedAt DateTime @updatedAt
}

/// Aidat / ödeme kaydı. Tutar TL cinsinden tam sayı (kuruş yok — basitlik).
model Payment {
  id        String   @id @default(cuid())
  athleteId String
  athlete   Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  amount    Int // ₺ (tam sayı)
  period    String // dönem etiketi, örn. "Haziran 2026" veya açıklama
  status    String   @default("pending") // paid | pending | overdue
  dueDate   String? // "YYYY-MM-DD"
  paidAt    String? // "YYYY-MM-DD"
  method    String? // nakit | havale | kart
  note      String?
  createdAt DateTime @default(now())

  @@index([athleteId])
  @@index([status])
}

/// Sporcuya atanan içerik: mesaj/direktif veya doküman.
model AthleteAssignment {
  id        String    @id @default(cuid())
  athleteId String
  athlete   Athlete   @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  kind      String    @default("message") // message | document
  title     String
  body      String    @default("")
  fileUrl   String? // doküman (storage.ts üzerinden)
  readAt    DateTime? // sporcu ilk görüntülediğinde
  createdAt DateTime  @default(now())

  @@index([athleteId, createdAt])
}

/// Beslenme programı — sporcuya atanır; öğünler günlük şablondur.
/// KVKK: öğün günlüğü sağlık-ilişkili veridir; görünürlük admin + sporcunun kendisi.
model NutritionPlan {
  id        String          @id @default(cuid())
  athleteId String
  athlete   Athlete         @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  title     String
  startDate String // "YYYY-MM-DD"
  endDate   String? // boş = açık uçlu
  notes     String          @default("")
  active    Boolean         @default(true)
  meals     NutritionMeal[]
  createdAt DateTime        @default(now())

  @@index([athleteId, active])
}

/// Program öğünü (günlük şablon satırı) + hedef makrolar (opsiyonel).
model NutritionMeal {
  id      String        @id @default(cuid())
  planId  String
  plan    NutritionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  name    String // Kahvaltı | Ara Öğün | Öğle | Akşam | ...
  time    String        @default("") // "08:00"
  content String        @default("") // ne yenecek (serbest metin)
  kcal    Int? // hedef makrolar
  protein Int? // gram
  carbs   Int?
  fat     Int?
  sort    Int           @default(0)
  logs    MealLog[]

  @@index([planId])
}

/// Sporcunun öğün günlüğü — öğün+gün başına TEK kayıt (upsert).
model MealLog {
  id        String        @id @default(cuid())
  mealId    String
  meal      NutritionMeal @relation(fields: [mealId], references: [id], onDelete: Cascade)
  athleteId String
  athlete   Athlete       @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  date      String // "YYYY-MM-DD"
  photoUrl  String? // öğün fotoğrafı
  note      String        @default("")
  kcal      Int? // gerçekleşen (opsiyonel)
  protein   Int?
  carbs     Int?
  fat       Int?
  createdAt DateTime      @default(now())

  @@unique([mealId, athleteId, date])
  @@index([athleteId, date])
}

/// Teknik ekip / yönetim üyesi — site sayfaları (yonetim, antrenorler) buradan beslenir.
model StaffMember {
  id        String   @id @default(cuid())
  name      String
  title     String // "Teknik Direktör", "U-15 Antrenörü", "Başkan"...
  group     String   @default("antrenor") // antrenor | yonetim
  licence   String? // "UEFA A", "TFF B"...
  photoUrl  String?
  bio       String   @default("")
  sort      Int      @default(0)
  createdAt DateTime @default(now())

  @@index([group])
}

/// Tesis — /kurumsal/tesisler buradan beslenir.
model Facility {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  capacity    String? // "2× tam saha", "300 kişilik tribün"...
  features    String   @default("") // virgülle ayrılmış özellik listesi
  photoUrl    String?
  /// true ise Takvim Programı'nda "saha" seçeneği olarak listelenir (elle işaretlenir).
  isPitch     Boolean  @default(false)
  sort        Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([isPitch])
}

/// Puan durumu satırı — admin tek tek yönetir; /fikstur/puan-durumu buradan beslenir.
model StandingRow {
  id           String   @id @default(cuid())
  teamName     String
  isOurs       Boolean  @default(false)
  played       Int      @default(0)
  wins         Int      @default(0)
  draws        Int      @default(0)
  losses       Int      @default(0)
  goalsFor     Int      @default(0)
  goalsAgainst Int      @default(0)
  points       Int      @default(0)
  sort         Int      @default(0) // sıralama (1 = lider)
  createdAt    DateTime @default(now())
}

/// Sporcu/veli paneli bildirim feed'i. BİRİNCİL kanal — her sistem olayı (antrenman,
/// maç, ölçüm, mesaj, beslenme) ve admin bildirimi önce buraya yazılır; Web Push
/// opsiyonel/non-blocking ek katmandır.
/// KVKK: body'ye sağlık/performans DEĞERİ yazılmaz (yalnız "yeni ölçümün eklendi" gibi).
model Notification {
  id        String    @id @default(cuid())
  athleteId String
  athlete   Athlete   @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  type      String // training | match | measurement | message | nutrition | admin
  title     String
  body      String    @default("")
  url       String? // site içi yol (internalPath ile doğrulanır)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([athleteId, createdAt])
  @@index([athleteId, readAt])
}

/// İş ilanı — /kurumsal/kariyer buradan beslenir; admin panelden yönetilir.
model JobPosting {
  id          String           @id @default(cuid())
  title       String
  department  String           @default("")
  location    String           @default("")
  employment  String           @default("full-time") // full-time | part-time | stajyer
  description String           @default("")
  active      Boolean          @default(true)
  sort        Int              @default(0)
  createdAt   DateTime         @default(now())
  applications JobApplication[]

  @@index([active])
}

/// İş başvurusu (public form). KVKK: aydınlatma+rıza kayıt-İÇİNDE denetim izli
/// tutulur (metin hash + sürüm + an + IP/UA) — sporcu tarafının çok-belgeli
/// ConsentRecord sistemi burada TEKRARLANMAZ (tek seferlik, yetişkin başvuran).
model JobApplication {
  id              String      @id @default(cuid())
  postingId       String?
  posting         JobPosting? @relation(fields: [postingId], references: [id], onDelete: SetNull)
  name            String
  email           String
  phone           String?
  message         String      @default("")
  cvUrl           String? // isOwnStorageUrl ile doğrulanır (PDF/görsel)
  status          String      @default("new") // new | reviewing | closed
  // KVKK denetim izi (kayıt-içi)
  consentTextHash String // gösterilen aydınlatma+rıza metninin SHA-256'sı
  consentVersion  String // metin sürümü (ispat)
  consentedAt     DateTime    @default(now())
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime    @default(now())

  @@index([postingId])
  @@index([status])
  @@index([createdAt])
}
