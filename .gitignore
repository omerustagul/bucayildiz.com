# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (gerçek değerler asla commit edilmez)
.env*
# ...ama şablonlar paylaşılır:
!.env.example
!.env.production.example

# prisma — local dev database
/prisma/*.db
/prisma/*.db-journal

# uploaded media (dev local storage)
/public/uploads

# geçici / çalışma alanı (commit edilmez)
/silinecek
/.playwright-mcp

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# yerel veritabani yedekleri (asla commit edilmez)
backups/

# Claude Code yerel arac dosyalari (launch.json, settings.local.json vb.) —
# proje komut/agent/skill'leri (.claude/commands, agents, skills, settings.json) izlenir.
.claude/*
!.claude/agents/
!.claude/commands/
!.claude/skills/
!.claude/settings.json

# IDE
.idea/
