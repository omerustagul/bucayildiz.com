# Buca Yıldız — ortam değişkenleri ŞABLONU (geliştirme)
# Bu dosyayı `.env` olarak kopyalayıp değerleri doldurun. Gerçek `.env`
# dosyası git'e EKLENMEZ. Üretim için `.env.production.example`'a bakın.

# --- Veritabanı (PostgreSQL) ---
# Dev (bu makine, Windows): native PostgreSQL 18, port 5432. Prod: Türkiye'deki sunucu.
DATABASE_URL="postgresql://bucayildiz:bucayildiz_dev@127.0.0.1:5432/bucayildiz?schema=public"

# --- Auth: oturum JWT imzalama anahtarı ---
# Üretimde MUTLAKA güçlü rastgele değer: `openssl rand -hex 32`
AUTH_SECRET="dev-secret-change-in-production-0a1b2c3d4e5f6071"

# --- İlk admin (yalnızca seed scripti için) ---
SEED_ADMIN_EMAIL="admin@bucayildiz.com"
SEED_ADMIN_PASSWORD="BucaYildiz2026!"
SEED_ADMIN_NAME="Mehmet Koç"

# --- Web Push (VAPID) — dev için üret: node -e "console.log(require('web-push').generateVAPIDKeys())" ---
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:bilgi@bucayildiz.com"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""

# --- E-posta/SMTP (boşsa bildirimler atlanır) ---
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="Buca Yıldız <bilgi@bucayildiz.com>"
MAIL_TO_ADMIN="admin@bucayildiz.com"

# --- Dosya depolama (S3-uyumlu; boşsa yerel disk public/uploads) ---
S3_ENDPOINT=""
S3_REGION="auto"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_BASE_URL=""

# --- SMS (veli OTP/bildirim; boşsa atlanır, dev'de koda yazılır) ---
SMS_API_URL=""
SMS_API_USER=""
SMS_API_KEY=""
SMS_SENDER=""
