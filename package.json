    "jose": "^6.2.3",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.18.0",
    "next": "16.2.9",
    "nodemailer": "^9.0.0",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.35.3",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
